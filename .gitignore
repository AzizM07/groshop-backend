# ═══════════════════════════════════════════════════════════════════
# GROSHOP Backend .gitignore
# ═══════════════════════════════════════════════════════════════════

# Secrets et variables d'environnement
.env
.env.local
.env.*.local

# Python virtual environments
.venv/
venv/
env/
ENV/

# Python cache
__pycache__/
*.py[cod]
*.class
*.so

# Django
*.log
db.sqlite3
db.sqlite3-journal
media/
staticfiles/
static_root/

# Migrations générées automatiquement (optionnel, on garde souvent)
# */migrations/*.py
# !*/migrations/__init__.py

# IDE et éditeurs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg

# Tests et couverture
.coverage
.pytest_cache/
htmlcov/
.tox/

# Jupyter
.ipynb_checkpoints/

# Logs
logs/
*.log

# Fichiers temporaires
*.tmp
*.bak
